generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                String                          @id @default(cuid())
  name                              String
  email                             String                          @unique
  phone                             String?
  passwordHash                      String
  active                            Boolean                         @default(true)
  billingCycle                      String                          @default("calendar_month")
  roles                             UserRole[]
  poolScheduleBlocks                PoolScheduleBlock[]
  poolClassesAsTeacher              PoolScheduleBlock[]             @relation("PoolClassTeacher")
  passwordResetTokens               PasswordResetToken[]
  personalTrainingPaymentsAsTeacher PersonalTrainingPayment[]       @relation("PersonalTrainingTeacher")
  personalTrainingPaymentsCreated   PersonalTrainingPayment[]       @relation("PersonalTrainingCreatedBy")
  personalTrainingBookingsAsTeacher PersonalTrainingBooking[]       @relation("PersonalTrainingBookingTeacher")
  substitutionRequestsAsAbsent      GroupClassSubstitutionRequest[] @relation("SubstitutionAbsentTeacher")
  substitutionRequestsCreated       GroupClassSubstitutionRequest[] @relation("SubstitutionRequestedBy")
  substitutionItemsAsSubstitute     GroupClassSubstitutionItem[]    @relation("SubstitutionSubstituteTeacher")
  createdAt                         DateTime                        @default(now())
  updatedAt                         DateTime                        @updatedAt
}

model Role {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  description String?
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  description String?
  roles       RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model PoolScheduleBlock {
  id                String                       @id @default(cuid())
  poolKey           String                       @default("piscina_25m")
  weekday           Int
  laneNumber        Int
  startMinutes      Int
  endMinutes        Int
  title             String
  type              String
  notes             String?
  active            Boolean                      @default(true)
  recurrenceType    String                       @default("recurring")
  validFrom         DateTime?                    @db.Date
  validTo           DateTime?                    @db.Date
  teacherId         String?
  teacher           User?                        @relation("PoolClassTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  createdById       String?
  createdBy         User?                        @relation(fields: [createdById], references: [id], onDelete: SetNull)
  bookings          PersonalTrainingBooking[]
  substitutionItems GroupClassSubstitutionItem[]
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt

  @@index([poolKey, weekday, laneNumber, startMinutes, endMinutes])
}

model GroupClassSubstitutionRequest {
  id               String                       @id @default(cuid())
  absentTeacherId  String
  absentTeacher    User                         @relation("SubstitutionAbsentTeacher", fields: [absentTeacherId], references: [id], onDelete: Restrict)
  requestedById    String?
  requestedBy      User?                        @relation("SubstitutionRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  substitutionDate DateTime                     @db.Date
  status           String                       @default("pending")
  cancelledAt      DateTime?
  cancelledById    String?
  cancelledByName  String?
  cancelReason     String?
  items            GroupClassSubstitutionItem[]
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  @@index([absentTeacherId, substitutionDate])
  @@index([status, substitutionDate])
}

model GroupClassSubstitutionItem {
  id                  String                        @id @default(cuid())
  requestId           String
  request             GroupClassSubstitutionRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  poolScheduleBlockId String
  poolScheduleBlock   PoolScheduleBlock             @relation(fields: [poolScheduleBlockId], references: [id], onDelete: Restrict)
  substituteTeacherId String
  substituteTeacher   User                          @relation("SubstitutionSubstituteTeacher", fields: [substituteTeacherId], references: [id], onDelete: Restrict)
  status              String                        @default("pending")
  accumulation        Boolean                       @default(false)
  poolKey             String
  laneNumber          Int
  title               String
  notes               String?
  startMinutes        Int
  endMinutes          Int
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt

  @@index([substituteTeacherId, status])
  @@index([poolScheduleBlockId])
}

model GroupClassHourlyRate {
  id                      String   @id @default(cuid())
  name                    String
  hourlyRate              Decimal  @db.Decimal(10, 2)
  matchSource             String   @default("title")
  matchPatterns           String?
  calculationMode         String   @default("class_duration")
  durationFilter          Int?
  weekendOnly             Boolean  @default(false)
  countByFortyFiveMinutes Boolean  @default(false)
  displayOrder            Int      @default(0)
  active                  Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([active, displayOrder])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PersonalTrainingPaymentType {
  id           String                    @id @default(cuid())
  description  String                    @unique
  credits      Int
  price        Decimal                   @default(0) @db.Decimal(10, 2)
  teacherPrice Decimal                   @default(0) @db.Decimal(10, 2)
  active       Boolean                   @default(true)
  payments     PersonalTrainingPayment[]
  bookings     PersonalTrainingBooking[]
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
}

model PersonalTrainingStudent {
  id           String                    @id @default(cuid())
  memberNumber String                    @unique
  fullName     String
  payments     PersonalTrainingPayment[]
  bookings     PersonalTrainingBooking[]
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
}

model PersonalTrainingPayment {
  id                  String                      @id @default(cuid())
  teacherId           String
  teacher             User                        @relation("PersonalTrainingTeacher", fields: [teacherId], references: [id], onDelete: Restrict)
  studentId           String
  student             PersonalTrainingStudent     @relation(fields: [studentId], references: [id], onDelete: Restrict)
  paymentTypeId       String
  paymentType         PersonalTrainingPaymentType @relation(fields: [paymentTypeId], references: [id], onDelete: Restrict)
  quantity            Int
  creditsPerUnit      Int
  totalCredits        Int
  pricePerUnit        Decimal                     @db.Decimal(10, 2)
  totalPrice          Decimal                     @db.Decimal(10, 2)
  teacherPricePerUnit Decimal                     @db.Decimal(10, 2)
  teacherTotal        Decimal                     @db.Decimal(10, 2)
  createdById         String?
  createdBy           User?                       @relation("PersonalTrainingCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  status              String                      @default("active")
  cancelledAt         DateTime?
  cancelledById       String?
  cancelledByName     String?
  cancelReason        String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  @@index([teacherId, studentId])
  @@index([status])
  @@index([createdAt])
}

model PersonalTrainingPaymentLog {
  id                  String   @id @default(cuid())
  paymentId           String
  teacherId           String
  studentId           String
  action              String
  teacherName         String
  studentName         String
  studentMemberNumber String
  paymentType         String
  quantity            Int
  totalCredits        Int
  totalPrice          Decimal  @db.Decimal(10, 2)
  teacherTotal        Decimal  @db.Decimal(10, 2)
  createdByName       String?
  actionById          String?
  actionByName        String
  reason              String?
  createdAt           DateTime @default(now())

  @@index([paymentId])
  @@index([teacherId, createdAt])
  @@index([createdAt])
}

model PersonalTrainingCreditAdjustment {
  id               String   @id @default(cuid())
  teacherId        String
  studentId        String
  trainingTypeKey  String
  trainingTypeName String
  deltaCredits     Int
  reason           String?
  createdById      String?
  createdByName    String
  createdAt        DateTime @default(now())

  @@index([teacherId, studentId])
  @@index([trainingTypeKey])
  @@index([createdAt])
}

model PersonalTrainingBooking {
  id              String                       @id @default(cuid())
  bookingGroupId  String                       @default(cuid())
  bookingDate     DateTime                     @db.Date
  poolBlockId     String
  poolBlock       PoolScheduleBlock            @relation(fields: [poolBlockId], references: [id], onDelete: Restrict)
  teacherId       String
  teacher         User                         @relation("PersonalTrainingBookingTeacher", fields: [teacherId], references: [id], onDelete: Restrict)
  studentId       String
  student         PersonalTrainingStudent      @relation(fields: [studentId], references: [id], onDelete: Restrict)
  paymentTypeId   String?
  paymentType     PersonalTrainingPaymentType? @relation(fields: [paymentTypeId], references: [id], onDelete: SetNull)
  startMinutes    Int
  endMinutes      Int
  durationMinutes Int
  creditsUsed     Int                          @default(1)
  status          String                       @default("scheduled")
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  @@index([bookingDate, poolBlockId])
  @@index([bookingGroupId])
  @@index([teacherId, bookingDate])
  @@index([studentId, bookingDate])
}

model PersonalTrainingBookingLog {
  id             String   @id @default(cuid())
  action         String
  bookingGroupId String
  bookingDate    DateTime @db.Date
  teacherName    String
  studentNames   String
  paymentType    String?
  poolBlockTitle String
  laneNumber     Int
  startMinutes   Int
  endMinutes     Int
  createdById    String?
  createdByName  String
  createdAt      DateTime @default(now())

  @@index([bookingDate])
  @@index([bookingGroupId])
}

model EmailSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  enabled   Boolean  @default(true)
  ccEmails  String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model SystemSettings {
  id                                   String   @id @default(cuid())
  key                                  String   @unique
  maintenanceMode                      Boolean  @default(true)
  includeLisbonMunicipalHolidays       Boolean  @default(false)
  includeChristmasEveHoliday           Boolean  @default(false)
  includeNewYearsEveHoliday            Boolean  @default(false)
  excludeDockSupportOverlapWithClasses Boolean  @default(false)
  updatedAt                            DateTime @updatedAt
  createdAt                            DateTime @default(now())
}

model EmailLog {
  id         String   @id @default(cuid())
  type       String
  status     String
  toEmail    String
  ccEmails   String?
  subject    String
  providerId String?
  error      String?
  paymentId  String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([type])
  @@index([status])
}
